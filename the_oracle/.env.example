# THE ORACLE — environment template
# Copy to .env (root of the repo) and fill in real values. Never commit .env.

# Gemini API key — obtain from https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Gemini model to use. gemini-flash-latest is the default (an alias that points
# to the current best Flash model and is available in the free tier).
GEMINI_MODEL=gemini-flash-latest

# HTTP port for the Express server
PORT=3000
