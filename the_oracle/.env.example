# THE ORACLE — environment template
# Copy to .env (in the_oracle/ directory) and fill in real values. Never commit .env.
#
# The default values for the variables below are defined in src/config.mjs.
# Changing the default there changes it everywhere (service, tests, docs).

# Gemini API key — obtain from https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Gemini model to use. Leave blank to use the default from src/config.mjs.
# To override, set e.g. GEMINI_MODEL=gemini-flash-latest
GEMINI_MODEL=

# HTTP port for the Express server. Leave blank to use the default from src/config.mjs.
PORT=
